client
dev tun
proto udp
remote vpn.example.com 1194
resolv-retry infinite
nobind
persist-key
persist-tun
auth-user-pass
static-challenge "Please enter your OTP token" 1
remote-cert-tls server
cipher AES-256-GCM
tls-auth ta.key 1
verb 3

<ca>
-----BEGIN CERTIFICATE-----
MIIBozCCAUmgAwIBAgIJAP...fake...data
-----END CERTIFICATE-----
</ca>

<cert>
-----BEGIN CERTIFICATE-----
MIIBozCCAUmgAwIBAgIJAP...fake...data
-----END CERTIFICATE-----
</cert>

<key>
-----BEGIN PRIVATE KEY-----
MIIBozCCAUmgAwIBAgIJAP...fake...data
-----END PRIVATE KEY-----
</key>

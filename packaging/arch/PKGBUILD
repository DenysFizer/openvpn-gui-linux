# Maintainer: Denys Fizer <fizerdenys@gmail.com>
pkgname=openvpn-gui-linux
pkgver=0.1.0
pkgrel=1
pkgdesc="A simple Linux GUI for OpenVPN"
arch=('x86_64')
url="https://github.com/DenysFizer/openvpn-gui-linux"
license=('MIT')
depends=('openvpn' 'polkit')
makedepends=('cargo' 'rust')
source=("$pkgname-$pkgver.tar.gz::$url/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

prepare() {
    cd "$pkgname-$pkgver"
    cargo fetch --locked
}

build() {
    cd "$pkgname-$pkgver"
    cargo build --release --locked --frozen
}

check() {
    cd "$pkgname-$pkgver"
    cargo test --release --locked --frozen
}

package() {
    cd "$pkgname-$pkgver"
    install -Dm755 "target/release/$pkgname" "$pkgdir/usr/bin/$pkgname"
    install -Dm644 "packaging/$pkgname.desktop" \
        "$pkgdir/usr/share/applications/$pkgname.desktop"
    install -Dm644 "assets/logo.png" \
        "$pkgdir/usr/share/icons/hicolor/256x256/apps/$pkgname.png"
}
